# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=k8s_platform

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-32-chars-minimum
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Services ─────────────────────────────────────────────────
ML_SERVICE_URL=http://ml-service:8001
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/k8s_platform

# ─── Notifications ────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_SIGNING_SECRET=your-slack-signing-secret
AWS_SES_REGION=eu-west-1
ALERT_EMAIL_FROM=alerts@yourcompany.com
ALERT_EMAIL_TO=devops@yourcompany.com

# ─── Risk Score thresholds ────────────────────────────────────
RISK_THRESHOLD_MEDIUM=26
RISK_THRESHOLD_HIGH=51
RISK_THRESHOLD_CRITICAL=76

# ─── Incident Response delays (seconds) ───────────────────────
IR_DELAY_IMMEDIATE=0
IR_DELAY_ML_DETECTION=120
IR_DELAY_ROLLBACK=300

# ─── Circuit breaker ──────────────────────────────────────────
CIRCUIT_BREAKER_FAIL_THRESHOLD=3
CIRCUIT_BREAKER_RESET_TIMEOUT=300

# ─── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_INGEST=1000/minute
RATE_LIMIT_REST=100/minute

# ─── Environment ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
